# Which whisper.cpp model to load. Downloaded on first start into a named volume.
# Options: tiny, base, small, medium, large-v1, large-v2, large-v3, large-v3-turbo
# (and *.en variants for English-only, e.g. small.en).
WHISPER_MODEL=large-v3

# CPU threads for inference.
WHISPER_THREADS=4

# Default language ("auto" detects per request; OpenAI clients can override
# via the `language` form field).
WHISPER_LANGUAGE=auto

# Image to run. The published :main-amx tag is built with -march=native on a
# Granite/Sapphire Rapids CPU and uses AMX kernels — will SIGILL on hosts
# without AMX. For non-AMX hosts, build locally (docker compose build) or
# pin :main once a portable build is published.
IMAGE=ghcr.io/aidenlabsdotdev/whisper-cpp-openai:main-amx

# Host port for the OpenAI-compatible HTTP server.
HOST_PORT=8000

# If set, requires Authorization: Bearer <key> on every request. Empty = open.
SHIM_API_KEY=
