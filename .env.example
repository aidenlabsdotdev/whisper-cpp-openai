# Which whisper.cpp model to load. Downloaded on first start into a named volume.
# Options: tiny, base, small, medium, large-v1, large-v2, large-v3, large-v3-turbo
# (and *.en variants for English-only, e.g. small.en)
WHISPER_MODEL=large-v3

# CPU threads for inference
WHISPER_THREADS=4

# Default language ("auto" detects per request; OpenAI clients can override via `language` field)
WHISPER_LANGUAGE=auto

# Whisper backend image.
# - main-amx: built with -march=native on a Granite/Sapphire Rapids host; uses
#   AMX_INT8/AMX_BF16 kernels. Will SIGILL on CPUs without AMX.
# - ghcr.io/ggml-org/whisper.cpp:main: upstream prebuilt, portable, no AMX.
# - ghcr.io/ggml-org/whisper.cpp:main-cuda: upstream CUDA build for GPU hosts.
WHISPER_IMAGE=ghcr.io/aidenlabsdotdev/whisper.cpp:main-amx

# Shim image. Override to pin a specific tag (e.g. :sha-abc123 or :v1.0.0).
SHIM_IMAGE=ghcr.io/aidenlabsdotdev/whisper-cpp-openai:latest

# Host port for the OpenAI-compatible shim
SHIM_PORT=8000

# If set, shim requires `Authorization: Bearer <SHIM_API_KEY>`. Leave empty to disable.
SHIM_API_KEY=
